---
import { asc } from 'drizzle-orm'
import AppNav from '../../components/AppNav.astro'
import ArticleList from '../../components/ArticleList.astro'
import { FeaturedReorder } from '../../components/FeaturedReorder'
import { getAppDb } from '../../db'
import { photoTags } from '../../db/schema'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { listOrdered } from '../../lib/apps/repo'
import { listFeatured, listRecent } from '../../lib/articles/queries'
import { imageUrl } from '../../lib/media/image-url'

// Defense in depth: the middleware already gates /app/*, but never render
// this page without a resolved user.
const user = Astro.locals.user
if (!user) {
  return Astro.redirect('/api/auth/login', 302)
}

const db = getAppDb()
const [featured, recent, photoHubs, apps] = await Promise.all([
  listFeatured(db),
  listRecent(db, 10),
  // Photo hubs = photo tags (REQUIREMENTS "Google Photos hub widget"),
  // linking into the hub's per-tag pages.
  db.select().from(photoTags).orderBy(asc(photoTags.name)),
  listOrdered(db),
])
---

<BaseLayout title="peterjur.co — app">
  <AppNav />
  <main class="admin-shell app-home">
    <h1>Hello, {user.email}</h1>

    <section aria-labelledby="featured-heading">
      <h2 id="featured-heading">Featured articles</h2>
      <FeaturedReorder
        client:load
        items={featured.map(({ id, title }) => ({ id, title }))}
      />
    </section>

    <section aria-labelledby="recent-heading">
      <h2 id="recent-heading">Recent articles</h2>
      <ArticleList articles={recent} emptyState="No articles yet." />
      <p><a href="/app/articles">All articles →</a></p>
    </section>

    <section aria-labelledby="photo-hubs-heading">
      <h2 id="photo-hubs-heading">Photo hubs</h2>
      {photoHubs.length === 0 && <p>No photo hubs yet.</p>}
      <ul class="hub-list">
        {
          photoHubs.map((hub) => (
            <li>
              <a href={`/app/photos/tags/${hub.id}`}>{hub.name}</a>
              <span class={`badge badge-${hub.visibility}`}>
                {hub.visibility}
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="my-apps-heading">
      <h2 id="my-apps-heading">My apps</h2>
      {apps.length === 0 && <p>No apps yet.</p>}
      <ul class="app-list">
        {
          apps.map((app) => (
            <li>
              {app.iconKey && (
                <img
                  class="app-icon"
                  src={imageUrl(app.iconKey, { width: 32, height: 32 })}
                  alt=""
                  loading="lazy"
                />
              )}
              <a href={app.url} target="_blank" rel="noreferrer">
                {app.name}
              </a>
            </li>
          ))
        }
      </ul>
      <p><a href="/app/admin/apps">Manage apps →</a></p>
    </section>
  </main>
</BaseLayout>

<style>
  .app-home section {
    margin-bottom: 2rem;
  }
  .app-home h2 {
    font-size: 1.1rem;
    border-bottom: 1px solid var(--admin-border-light, #eee);
    padding-bottom: 0.25rem;
  }
  /* Widget-slot lists (Photo hubs, My apps) — article lists render via the
     shared ArticleList component. */
  .app-home ul {
    padding: 0;
    list-style: none;
  }
  .app-home li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.35rem 0;
  }
  .app-home li a {
    font-weight: 600;
    color: var(--admin-accent, #333);
  }
  .app-icon {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 4px;
    object-fit: cover;
  }
</style>
