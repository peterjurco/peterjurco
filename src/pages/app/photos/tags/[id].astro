---
import AppNav from '../../../../components/AppNav.astro'
import { getAppDb } from '../../../../db'
import BaseLayout from '../../../../layouts/BaseLayout.astro'
import { parseId } from '../../../../lib/api'
import { imageUrl } from '../../../../lib/media/image-url'
import { getTagById, listByTag } from '../../../../lib/photos/repo'

// Defense in depth: the middleware already gates /app/*.
if (!Astro.locals.user) {
  return Astro.redirect('/api/auth/login', 302)
}

// Auth-only listing pages use the plain internal id (DATA_MODEL: no
// enumeration risk behind the login wall).
const id = parseId(Astro.params.id)
if (id === null) {
  return new Response('Not found', { status: 404 })
}

const db = getAppDb()
const tag = await getTagById(db, id)
if (!tag) {
  return new Response('Not found', { status: 404 })
}
const albums = await listByTag(db, id)
const nextVisibility = tag.visibility === 'private' ? 'public' : 'private'
---

<BaseLayout title={`#${tag.name} — peterjur.co`}>
  <AppNav />
  <main class="admin-shell tag-page">
    <header>
      <h1>Tag: {tag.name}</h1>
      <span class={`badge badge-${tag.visibility}`}>{tag.visibility}</span>
      <button
        type="button"
        class="admin-btn"
        id="toggle-visibility"
        data-tag-id={tag.id}
        data-next={nextVisibility}
      >
        Make {nextVisibility}
      </button>
      {
        tag.visibility === 'public' && (
          <a href={`/t/${tag.publicId}`} target="_blank" rel="noreferrer">
            Public link
          </a>
        )
      }
    </header>
    {albums.length === 0 && <p>No albums with this tag.</p>}
    <ul>
      {
        albums.map((album) => (
          <li>
            {album.coverImageKey && (
              <img
                src={imageUrl(album.coverImageKey, { width: 480 })}
                alt=""
                loading="lazy"
              />
            )}
            <a
              href={album.googlePhotosUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              {album.name}
            </a>
          </li>
        ))
      }
    </ul>
    <p><a href="/app/photos">← Photo hub</a></p>
  </main>
</BaseLayout>

<script>
  // Owner-side "mark a tag as public" (REQUIREMENTS) — PATCH then reload so
  // the badge and public link re-render server-side. Failures alert instead
  // of silently doing nothing — this is a single-owner admin page.
  const button = document.getElementById('toggle-visibility')
  button?.addEventListener('click', async () => {
    const { tagId, next } = (button as HTMLElement).dataset
    try {
      const response = await fetch(`/api/photos/tags/${tagId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ visibility: next }),
      })
      if (!response.ok) throw new Error(`PATCH failed (${response.status})`)
      window.location.reload()
    } catch {
      window.alert('Could not change the tag visibility — please try again.')
    }
  })
</script>

<style>
  ul {
    padding: 0;
    list-style: none;
  }
  li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--admin-border-light, #eee);
  }
  li a {
    font-weight: 600;
    color: var(--admin-accent, #333);
  }
  img {
    width: 7rem;
    max-width: 30%;
    height: auto;
    border-radius: 4px;
  }
</style>
