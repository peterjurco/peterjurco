---
import { AlbumForm } from '../../../../components/AlbumForm'
import AppNav from '../../../../components/AppNav.astro'
import { getAppDb } from '../../../../db'
import BaseLayout from '../../../../layouts/BaseLayout.astro'
import { getAlbumById } from '../../../../lib/photos/repo'

// Defense in depth: the middleware already gates /app/*.
if (!Astro.locals.user) {
  return Astro.redirect('/api/auth/login', 302)
}

// Auth-only pages use the plain internal id (DATA_MODEL: no enumeration risk
// behind the login wall).
const id = Number(Astro.params.id)
if (!Number.isInteger(id) || id <= 0) {
  return new Response('Not found', { status: 404 })
}

const db = getAppDb()
const album = await getAlbumById(db, id)
if (!album) {
  return new Response('Not found', { status: 404 })
}
---

<BaseLayout title={`Edit ${album.name} — peterjur.co`}>
  <AppNav />
  <main class="album-page">
    <h1>Edit album</h1>
    <AlbumForm
      client:load
      albumId={album.id}
      initialName={album.name}
      initialGooglePhotosUrl={album.googlePhotosUrl}
      initialTags={album.tags.map((tag) => tag.name)}
      initialCoverImageKey={album.coverImageKey}
    />
    <p><a href="/app/photos">← Photo hub</a></p>
  </main>
</BaseLayout>

<style>
  .album-page {
    max-width: 46rem;
    margin: 0 auto;
    padding: 1rem;
    font-family: system-ui, sans-serif;
  }
</style>
