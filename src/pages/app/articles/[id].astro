---
import AppNav from '../../../components/AppNav.astro'
import { ArticleEditor } from '../../../components/ArticleEditor'
import { ArticleMetaPanel } from '../../../components/ArticleMetaPanel'
import { getAppDb } from '../../../db'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getById, listCategories } from '../../../lib/articles/repo'

// Defense in depth: the middleware already gates /app/*.
if (!Astro.locals.user) {
  return Astro.redirect('/api/auth/login', 302)
}

const id = Number(Astro.params.id)
if (!Number.isInteger(id) || id <= 0) {
  return new Response('Not found', { status: 404 })
}

const db = getAppDb()
const [article, categories] = await Promise.all([
  getById(db, id),
  listCategories(db),
])
if (!article) {
  return new Response('Not found', { status: 404 })
}
---

<BaseLayout title={`${article.title || 'Untitled'} — peterjur.co`}>
  <AppNav />
  <main class="article-editor-page">
    <ArticleMetaPanel
      client:load
      articleId={article.id}
      publicId={article.publicId}
      initialTitle={article.title}
      initialVisibility={article.visibility}
      initialCategoryId={article.categoryId}
      initialTags={article.tags.map((tag) => tag.name)}
      initialIsFeatured={article.isFeatured}
      categories={categories.map(({ id, name }) => ({ id, name }))}
    />
    <ArticleEditor
      client:load
      articleId={article.id}
      editable={true}
      initialContent={article.content as Record<string, unknown>}
    />
  </main>
</BaseLayout>

<style>
  .article-editor-page {
    padding: 1rem;
    font-family: system-ui, sans-serif;
  }
</style>
