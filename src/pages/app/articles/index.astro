---
import AppNav from '../../../components/AppNav.astro'
import { getAppDb } from '../../../db'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { listForOwner } from '../../../lib/articles/repo'
import { formatDate } from '../../../lib/format-date'

// Defense in depth: the middleware already gates /app/*.
if (!Astro.locals.user) {
  return Astro.redirect('/api/auth/login', 302)
}

const db = getAppDb()
const articles = await listForOwner(db)
---

<BaseLayout title="Articles — peterjur.co">
  <AppNav />
  <main class="admin-shell articles-list">
    <header>
      <h1>Articles</h1>
      <form method="post" action="/app/articles/new">
        <button type="submit" class="admin-btn admin-btn--primary">
          New article
        </button>
      </form>
    </header>
    {articles.length === 0 && <p>No articles yet.</p>}
    <ul>
      {
        articles.map((article) => (
          <li>
            <a href={`/app/articles/${article.id}`}>
              {article.title || 'Untitled'}
            </a>
            {article.categoryName && (
              <span class="category">{article.categoryName}</span>
            )}
            <span class={`badge badge-${article.visibility}`}>
              {article.visibility}
            </span>
            {article.isFeatured && <span class="badge">featured</span>}
            <time datetime={article.updatedAt.toISOString()}>
              {formatDate(article.updatedAt)}
            </time>
          </li>
        ))
      }
    </ul>
    <p><a href="/app">← Back</a></p>
  </main>
</BaseLayout>

<style>
  ul {
    padding: 0;
    list-style: none;
  }
  li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--admin-border-light, #eee);
  }
  li a {
    font-weight: 600;
    color: var(--admin-accent, #333);
  }
  .category {
    color: var(--admin-muted, #666);
    font-size: 0.85rem;
  }
  time {
    margin-left: auto;
    color: var(--admin-faint, #999);
    font-size: 0.8rem;
  }
</style>
