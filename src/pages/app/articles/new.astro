---
import { getAppDb } from '../../../db'
import { createArticle } from '../../../lib/articles/repo'

// Defense in depth: the middleware already gates /app/*.
if (!Astro.locals.user) {
  return Astro.redirect('/api/auth/login', 302)
}

// Creation mutates state → POST only (the list page submits a form here); a
// stray GET (link prefetch, typed URL) must not create articles.
if (Astro.request.method !== 'POST') {
  return Astro.redirect('/app/articles', 302)
}

const article = await createArticle(getAppDb())
return Astro.redirect(`/app/articles/${article.id}`, 302)
---
