---
import AppNav from '../../../components/AppNav.astro'
import ArticleList from '../../../components/ArticleList.astro'
import { getAppDb } from '../../../db'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getCategoryById, listByCategory } from '../../../lib/articles/queries'

// Defense in depth: the middleware already gates /app/*.
if (!Astro.locals.user) {
  return Astro.redirect('/api/auth/login', 302)
}

// Auth-only listing pages use the plain internal id (DATA_MODEL: no
// enumeration risk behind the login wall).
const id = Number(Astro.params.id)
if (!Number.isInteger(id) || id <= 0) {
  return new Response('Not found', { status: 404 })
}

const db = getAppDb()
const category = await getCategoryById(db, id)
if (!category) {
  return new Response('Not found', { status: 404 })
}
const articles = await listByCategory(db, id)
---

<BaseLayout title={`${category.name} — peterjur.co`}>
  <AppNav />
  <main class="taxonomy-list">
    <header>
      <h1>Category: {category.name}</h1>
    </header>
    <ArticleList articles={articles} emptyState="No articles in this category." />
    <p><a href="/app/articles">← Articles</a></p>
  </main>
</BaseLayout>

<style>
  .taxonomy-list {
    max-width: 46rem;
    margin: 0 auto;
    padding: 1rem;
    font-family: system-ui, sans-serif;
  }
</style>
