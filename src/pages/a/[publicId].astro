---
import { env } from 'cloudflare:workers'
import { getDb } from '../../db'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { deriveExcerpt } from '../../lib/articles/excerpt'
import { renderDoc } from '../../lib/articles/render-doc'
import { getByPublicId } from '../../lib/articles/repo'
import { requireEnv } from '../../lib/env'

// Public read view (TECH_DECISIONS §9): pure SSR — no editor JS is shipped.
// getByPublicId returns only public articles, so private ids 404 here.
const db = getDb(requireEnv(env.DATABASE_URL, 'DATABASE_URL'))
const article = await getByPublicId(db, Astro.params.publicId ?? '')
if (!article) {
  return new Response('Not found', { status: 404 })
}

const title = article.title || 'Untitled'
const description = deriveExcerpt(article.content, 200)
const html = renderDoc(article.content)
const canonicalUrl = new URL(Astro.url.pathname, Astro.url)
// Media serving lands in Plan 5 — until then featured_photo_key is null and
// cards simply have no image. `/media/:key` is the planned public route.
const imageUrl = article.featuredPhotoKey
  ? new URL(`/media/${article.featuredPhotoKey}`, Astro.url)
  : null
---

<BaseLayout title={title}>
  <Fragment slot="head">
    <meta name="description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta
      name="twitter:card"
      content={imageUrl ? 'summary_large_image' : 'summary'}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
  </Fragment>
  <main class="public-article">
    <article>
      <h1>{title}</h1>
      <div class="article-body" set:html={html} />
    </article>
  </main>
</BaseLayout>

<style is:global>
  .public-article {
    max-width: 42rem;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
    font-family: Georgia, serif;
    line-height: 1.7;
  }
  .public-article h1 {
    line-height: 1.2;
  }
  .article-body blockquote {
    margin: 1rem 0;
    padding-left: 1rem;
    border-left: 3px solid #ccc;
    color: #555;
  }
  .article-body img {
    max-width: 100%;
    height: auto;
  }
  .article-body a {
    color: #0645ad;
  }
</style>
