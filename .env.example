# Neon pooled connection string, e.g.
# postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
# In production this is a Cloudflare Pages secret (never committed).
DATABASE_URL=

# Local/CI Postgres used by the test suite (see tests/helpers/test-db.ts).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5544/peterjurco_test

# --- Auth (Cloudflare Pages secrets in production, .dev.vars locally) -------

# Google OAuth2 credentials (Google Cloud Console → APIs & Services →
# Credentials). Identity-only scopes — the app never requests Drive/Photos.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an authorized redirect URI on the OAuth client,
# e.g. https://peterjur.co/api/auth/callback (or http://localhost:4321/... in dev).
GOOGLE_REDIRECT_URI=

# HMAC-SHA256 key for signing auth cookies. Generate with e.g.
# `openssl rand -base64 32`. Rotating it invalidates every issued cookie.
SESSION_SECRET=

# Comma-separated, case-insensitive list of Google account emails allowed to
# sign in. Anyone else gets a 403 after the Google consent screen.
AUTH_ALLOWED_EMAILS=

# --- Media (R2 + Cloudflare Images) ------------------------------------------

# R2 S3-API credentials for presigned uploads (Cloudflare dashboard → R2 →
# Manage API tokens). Cloudflare Pages secrets in production, .dev.vars locally.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Test-only S3 endpoint override — points the presigner at local MinIO
# (docker-compose.test.yml). Leave unset in production (derived from
# R2_ACCOUNT_ID: https://<account>.r2.cloudflarestorage.com).
R2_ENDPOINT=

# Public base URL of the R2 bucket (custom domain or r2.dev) used to build
# image URLs. Build-time public var (import.meta.env).
PUBLIC_R2_PUBLIC_BASE_URL=
# Set to `off` where no Cloudflare zone serves /cdn-cgi/image/* (dev/tests) —
# images are then served as the stored originals.
PUBLIC_IMAGE_TRANSFORMS=
